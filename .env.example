# Скопируйте этот файл в .env и заполните значения

# Секретный ключ Django. Сгенерировать:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# True для разработки, False на сервере
DEBUG=True

# Список хостов через запятую (для продакшена)
ALLOWED_HOSTS=localhost,127.0.0.1

# Срок действия ссылок на скачивание, в днях
DOWNLOAD_LINK_DAYS=30

# Ключи ЮKassa (необязательно — без них оплата работает в демо-режиме)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
